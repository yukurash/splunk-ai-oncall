# ──────────────────────────────────────────────────────────────
# Splunk Observability Cloud
# ──────────────────────────────────────────────────────────────
# realm はトライアル登録時に選んだリージョン。MCP のため AWS 系を選ぶこと
# (例: us0 / us1 / eu0)。GCP / GovCloud 系は MCP 非対応。
SPLUNK_REALM=us1

# API アクセストークン (Settings → Access Tokens)
SPLUNK_ACCESS_TOKEN=

# ──────────────────────────────────────────────────────────────
# ログ送信用 (任意。トレース/メトリクスだけでも実験は成立する)
# ──────────────────────────────────────────────────────────────
# O11y のログ ingest を使う場合のエンドポイントとトークン
SPLUNK_HEC_URL=https://ingest.us1.signalfx.com/v1/log
SPLUNK_HEC_TOKEN=

# ──────────────────────────────────────────────────────────────
# Splunk MCP gateway (Claude Code から接続するエンドポイント)
# realm/リージョンに対応した URL を Splunk の手順で確認して設定する。
# 形式例: https://region-<r>.api.scs.splunk.com/system/mcp-gateway/v1/
# ──────────────────────────────────────────────────────────────
SPLUNK_MCP_URL=

# ──────────────────────────────────────────────────────────────
# OpenTelemetry Demo
# ──────────────────────────────────────────────────────────────
# clone した demo のパス (set-flag スクリプトが flagd 設定を編集する)
OTEL_DEMO_DIR=./opentelemetry-demo
